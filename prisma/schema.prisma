// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String    @id @default(uuid())
  name            String
  email           String    @unique
  password        String
  isBanned        Boolean   @default(false)
  bannedAt        DateTime?
  emailVerifiedAt DateTime?
  roleId          String?
  role            Role?     @relation(fields: [roleId], references: [id])

  createdAt DateTime @default(now())

  vacancies               Vacancy[]
  companyMemberships      CompanyMember[]
  posts                   Post[]
  media                   Media[]
  contentVersions         ContentVersion[]
  refreshTokens           RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]

  @@index([roleId])
  @@index([isBanned])
  @@index([createdAt])
}

model EmailVerificationToken {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
}

model Role {
  id   String @id @default(uuid())
  name String @unique

  users          User[]
  companyMembers CompanyMember[]
  companyInvites CompanyInvite[]

  permissions RolePermission[]
}

model Permission {
  id          String  @id @default(uuid())
  key         String  @unique
  description String?

  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model RefreshToken {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Vacancy {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  title        String
  description  String
  requirements String
  location     String
  contactEmail String

  salary String?

  status VacancyStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deletedAt DateTime?

  versions VacancyVersion[]
  tags     VacancyTag[]
}

model Company {
  id String @id @default(uuid())

  name        String
  slug        String  @unique
  description String?
  logo        String?
  website     String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  members   CompanyMember[]
  invites   CompanyInvite[]
  vacancies Vacancy[]

  contact           CompanyContact?
  socialLinks       CompanySocialLink[]
  projects          Project[]
  serviceCategories ServiceCategory[]
  services          Service[]
  partners          Partner[]
  posts             Post[]
  media             Media[]
  adSpaces          AdSpace[]
  ads               Ad[]
  adPlacements      AdPlacement[]
  siteSettings      CompanySiteSettings?
  translations      CompanyTranslation[]
}

model CompanyTranslation {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  locale      Locale
  name        String
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, locale])
  @@index([locale])
}

model CompanyMember {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  roleId String?
  role   Role?   @relation(fields: [roleId], references: [id])

  isOwner  Boolean  @default(false)
  joinedAt DateTime @default(now())

  @@unique([companyId, userId])
  @@index([userId])
  @@index([roleId])
}

model CompanyInvite {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  email String

  roleId String?
  role   Role?   @relation(fields: [roleId], references: [id])

  isOwner Boolean @default(false)

  tokenHash String   @unique
  expiresAt DateTime

  invitedBy  String?
  acceptedBy String?

  acceptedAt DateTime?
  revokedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, email])
  @@index([acceptedAt, revokedAt, expiresAt])
  @@index([email])
  @@index([expiresAt])
  @@index([roleId])
}

model CompanySiteSettings {
  id String @id @default(uuid())

  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id])

  domain    String? @unique
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([domain])
  @@index([isActive])
}

model CompanyContact {
  id String @id @default(uuid())

  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id])

  email    String?
  phone    String?
  address  String?
  location String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompanySocialLink {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  platform  String
  url       String
  username  String?
  sortOrder Int     @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([companyId])
}

model Project {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  title       String
  description String
  status      ProjectStatus @default(DRAFT)
  sortOrder   Int           @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tags         ProjectTag[]
  translations ProjectTranslation[]

  @@index([companyId])
  @@index([status])
}

model ProjectTranslation {
  id String @id @default(uuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  locale      Locale
  title       String
  description String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, locale])
  @@index([locale])
}

model ServiceCategory {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name        String
  slug        String
  description String?
  sortOrder   Int     @default(0)

  services     Service[]
  translations ServiceCategoryTranslation[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([companyId, slug])
  @@index([companyId])
}

model ServiceCategoryTranslation {
  id String @id @default(uuid())

  categoryId String
  category   ServiceCategory @relation(fields: [categoryId], references: [id])

  locale      Locale
  name        String
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([categoryId, locale])
  @@index([locale])
}

model Service {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  categoryId String?
  category   ServiceCategory? @relation(fields: [categoryId], references: [id])

  title       String
  description String
  sortOrder   Int    @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  translations ServiceTranslation[]

  @@index([companyId])
  @@index([categoryId])
}

model ServiceTranslation {
  id String @id @default(uuid())

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  locale      Locale
  title       String
  description String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([serviceId, locale])
  @@index([locale])
}

model Partner {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name      String
  website   String?
  logo      String?
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([companyId])
  @@index([isActive])
}

model Post {
  id String @id @default(uuid())

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  createdBy String?
  author    User?   @relation(fields: [createdBy], references: [id])

  title   String
  slug    String  @unique
  excerpt String?
  content String

  type   PostType   @default(NEWS)
  status PostStatus @default(DRAFT)

  isGlobal  Boolean @default(false)
  sortOrder Int     @default(0)

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  tags         PostTag[]
  translations PostTranslation[]

  @@index([companyId])
  @@index([createdBy])
  @@index([status])
  @@index([type])
  @@index([isGlobal])
}

model PostTranslation {
  id String @id @default(uuid())

  postId String
  post   Post   @relation(fields: [postId], references: [id])

  locale  Locale
  title   String
  excerpt String?
  content String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([postId, locale])
  @@index([locale])
}

model Media {
  id String @id @default(uuid())

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  createdBy String?
  author    User?   @relation(fields: [createdBy], references: [id])

  url    String
  type   MediaType
  locale Locale?

  mimeType     String?
  fileName     String?
  originalName String?
  size         Int?
  storage      String?

  entityType String?
  entityId   String?

  isGlobal  Boolean @default(false)
  altText   String?
  title     String?
  sortOrder Int     @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([companyId])
  @@index([createdBy])
  @@index([type])
  @@index([locale])
  @@index([isGlobal])
  @@index([entityType, entityId])
}

model ContentVersion {
  id String @id @default(uuid())

  entityType String
  entityId   String

  data    Json
  version Int

  createdBy String?
  user      User?   @relation(fields: [createdBy], references: [id])

  createdAt DateTime @default(now())

  @@unique([entityType, entityId, version])
  @@index([entityType, entityId])
  @@index([createdBy])
}

model AdSpace {
  id String @id @default(uuid())

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  name        String
  description String?
  locationKey String
  sortOrder   Int     @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  placements AdPlacement[]

  @@unique([companyId, locationKey])
  @@index([companyId])
}

model Ad {
  id String @id @default(uuid())

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  title     String
  type      AdType
  imageUrl  String?
  targetUrl String?
  embedCode String?

  isGlobal  Boolean @default(false)
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  startDate DateTime?
  endDate   DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  placements   AdPlacement[]
  translations AdTranslation[]

  @@index([companyId])
  @@index([isGlobal])
  @@index([isActive])
}

model AdTranslation {
  id String @id @default(uuid())

  adId String
  ad   Ad     @relation(fields: [adId], references: [id])

  locale Locale
  title  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([adId, locale])
  @@index([locale])
}

model AdPlacement {
  id String @id @default(uuid())

  adId String
  ad   Ad     @relation(fields: [adId], references: [id])

  spaceId String
  space   AdSpace @relation(fields: [spaceId], references: [id])

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  impressions Int @default(0)
  clicks      Int @default(0)
  sortOrder   Int @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([adId, spaceId])
  @@index([companyId])
  @@index([spaceId])
}

model Tag {
  id String @id @default(uuid())

  name String
  slug String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts     PostTag[]
  projects  ProjectTag[]
  vacancies VacancyTag[]
}

model PostTag {
  postId String
  tagId  String

  post Post @relation(fields: [postId], references: [id])
  tag  Tag  @relation(fields: [tagId], references: [id])

  @@id([postId, tagId])
  @@index([tagId])
}

model ProjectTag {
  projectId String
  tagId     String

  project Project @relation(fields: [projectId], references: [id])
  tag     Tag     @relation(fields: [tagId], references: [id])

  @@id([projectId, tagId])
  @@index([tagId])
}

model VacancyTag {
  vacancyId String
  tagId     String

  vacancy Vacancy @relation(fields: [vacancyId], references: [id])
  tag     Tag     @relation(fields: [tagId], references: [id])

  @@id([vacancyId, tagId])
  @@index([tagId])
}

enum VacancyStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  ARCHIVED
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PostType {
  NEWS
  BLOG
  ARTICLE
  ANNOUNCEMENT
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
  OTHER
}

enum Locale {
  EN
  RU
  TK
}

enum AdType {
  IMAGE
  HTML
  SCRIPT
}

model VacancyVersion {
  id String @id @default(uuid())

  vacancyId String
  vacancy   Vacancy @relation(fields: [vacancyId], references: [id])

  data Json

  version Int

  createdBy String
  createdAt DateTime @default(now())
}

model ActivityLog {
  id String @id @default(uuid())

  companyId String?
  userId    String?

  action     String
  entityType String
  entityId   String

  metadata Json?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())
}
