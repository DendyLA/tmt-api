NODE_ENV=production
PORT=3000

POSTGRES_DB=tmt
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
BACKEND_PORT=3000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tmt
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tmt_test

JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ACCESS_EXPIRES_IN=15m

APP_URL=http://localhost:3000
ENABLE_SWAGGER=true
TRUST_PROXY=false
CORS_ORIGINS=http://localhost:3000,https://example.com
REQUEST_BODY_LIMIT=1mb
MEDIA_MAX_FILE_SIZE_MB=20
MEDIA_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/gif,video/mp4,application/pdf
